# Copy this to .env and fill in your values, or export these directly in your shell.

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Optional fallback LLM — used automatically when Gemini fails (e.g. quota 429),
# so bulk re-propose survives a quota wall. Any OpenAI-compatible provider works:
# Groq (default), OpenRouter, Cerebras, Mistral. Free Groq key: https://console.groq.com/keys
# FALLBACK_LLM_API_KEY=gsk_your_key_here
# FALLBACK_LLM_BASE_URL=https://api.groq.com/openai/v1
# FALLBACK_LLM_MODEL=llama-3.3-70b-versatile
# Order providers are tried in. Use "fallback,gemini" to prefer the fallback and
# spare your Gemini quota. Append the special "heuristic" provider as a terminal,
# no-API fallback so a run never dies on a quota wall (mappings it makes are
# low-confidence and flagged for review):
# LLM_PROVIDER_ORDER=gemini,fallback,heuristic
# Or run the AI-agentic flow entirely OFFLINE (no key needed) with just:
# LLM_PROVIDER_ORDER=heuristic
# Privacy: prompts are schema-only (column names/types) — row values are never
# sent to any provider, safe for the free tiers that may train on submissions.

# Postgres target for a schema-swap / generic-writer run (e.g. old-lrmis restored):
# LRMIS_TARGET_PG_DSN=postgresql://postgres:postgres@localhost:5432/lrmis_target

CENTRAL_DB_URL=postgresql://postgres:postgres@localhost:5433/central
# LRMIS_STAGING_HOST=localhost
# LRMIS_STAGING_PORT=3307
# LRMIS_STAGING_DATABASE=lrmis_staging
# LRMIS_STAGING_USER=irimsv_writer
# LRMIS_STAGING_PASSWORD=change-me
# MySQL 8.4 accounts use caching_sha2_password, which cannot authenticate over
# an unencrypted TCP connection. Keep SSL enabled (false) unless the account
# uses mysql_native_password, or the least-privilege writer will fail to connect.
# LRMIS_STAGING_SSL_DISABLED=false
# LRMIS_TARGET_SYSTEM=LRMIS
# Path B parallel target database (Phase 1+). Same server, same credentials.
LRMIS_TARGET_DATABASE=lrmis_target
SOURCE_SYSTEM=IRIMSV_REGION_V
SYNC_INTERVAL_SECONDS=300
SYNC_BATCH_SIZE=100
SYNC_MAX_ATTEMPTS=8

# Admin web UI (src/admin_api) - generate a long random ADMIN_SESSION_SECRET
ADMIN_API_HOST=127.0.0.1
ADMIN_API_PORT=8400
ADMIN_SESSION_SECRET=
