# Copy this to .env and fill in your values, or export these directly in your shell.

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

CENTRAL_DB_URL=postgresql://postgres:postgres@localhost:5433/central
LRMIS_STAGING_HOST=localhost
LRMIS_STAGING_PORT=3307
LRMIS_STAGING_DATABASE=lrmis_staging
LRMIS_STAGING_USER=irimsv_writer
LRMIS_STAGING_PASSWORD=change-me
LRMIS_STAGING_SSL_DISABLED=true
LRMIS_TARGET_SYSTEM=LRMIS
SOURCE_SYSTEM=IRIMSV_REGION_V
SYNC_INTERVAL_SECONDS=300
SYNC_BATCH_SIZE=100
SYNC_MAX_ATTEMPTS=8
